# Model configuration
MODEL_NAME=Qwen/Qwen3-14B
QUANTIZE=false
MAX_TOKENS=1024

# HuggingFace configuration
HF_TOKEN=

# Server configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Database (Supabase Postgres — session pooler, async driver)
# Get the string from Supabase dashboard > Connect > Session pooler (port 5432).
# Change the scheme from postgresql:// to postgresql+asyncpg:// for SQLAlchemy async.
DATABASE_URL=postgresql+asyncpg://postgres.your-project-ref:YOUR_PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres

# Supabase Auth (used to verify JWTs server-side via supabase.auth.get_user)
# Find both under Supabase dashboard > Project Settings > API.
# The anon key is safe to use server-side for token verification.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
